# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Mapbox (public token, safe in client)
VITE_MAPBOX_TOKEN=

# Google Places API — SERVER SIDE ONLY
# Do NOT add a VITE_ prefix — this key must never reach the client
# Set as a Supabase Edge Function secret via:
#   Supabase Dashboard > Project Settings > Edge Functions > Secrets
#   Name: GOOGLE_PLACES_API_KEY
# GOOGLE_PLACES_API_KEY=

# Web Push VAPID — public key needed on client for push subscription
VITE_VAPID_PUBLIC_KEY=

# Web Push VAPID — SERVER SIDE ONLY, used in Edge Functions
# Set as Supabase Edge Function secrets (not in this file)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=
